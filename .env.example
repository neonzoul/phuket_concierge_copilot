# LLM provider (directive §3 — accessed only through packages/llm-providers, never SDK-direct)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase (database/auth/storage — directive §3). Not wired in the scaffold's in-memory
# repositories yet; set these when packages/database gets a Supabase-backed implementation.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Notification adapter (Slack mock for demo — directive §3)
SLACK_WEBHOOK_URL=

# Server
PORT=4100
NODE_ENV=development

# Property context loaded at boot (directive §5)
PROPERTY_SLUG=nai-harn-wellness-hideaway
